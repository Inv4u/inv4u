NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (server-only, bypasses RLS). SUPABASE_SERVICE_ROLE_KEY is the
# preferred name; SUPABASE_SERVICE_KEY is the legacy name still read as a fallback
# by the existing /api/leads flow. They hold the same value — set either/both.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_KEY=
# Where new-signup / approval-needed admin alerts are emailed (defaults to inv4u.business@gmail.com)
ADMIN_NOTIFICATION_EMAIL=

# Lead notification email (Gmail SMTP via nodemailer)
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Optional: where lead notifications are sent (defaults to inv4u.business@gmail.com)
LEAD_NOTIFY_TO=

# Twilio WhatsApp lead notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
NOTIFICATION_WHATSAPP_TO=
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
